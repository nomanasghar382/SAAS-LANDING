# Environment variables — copy to Vercel Dashboard → Settings → Environment Variables

# Required for production auth (generate: openssl rand -base64 32)
AUTH_SECRET=replace-with-random-32-plus-character-secret

# Set AFTER first deploy — use your real Vercel URL
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# App branding
NEXT_PUBLIC_APP_NAME=SellPilot AI
